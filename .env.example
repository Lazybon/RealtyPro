# Database (Neon / локальный Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fullstack_db?schema=public"

# Neon: для `npm run db:push:schema` / миграций — строка «Direct» из консоли (хост без фрагмента -pooler).
# Рантайм (Next/Railway) может использовать pooled DATABASE_URL.
# DIRECT_URL="postgresql://user:pass@ep-xxx.c-2.region.aws.neon.tech/neondb?sslmode=require"

# Если P1001: уберите из URL параметр channel_binding=require (часто мешает node-pg).
# Опционально: DATABASE_SSL=true | false | не задавать (авто при sslmode=require и облачных хостах)
# DATABASE_SSL=

# --- Railway (сервис API, из корня репозитория) ---
# DATABASE_URL — Neon pooled (как в приложении), без DIRECT_URL.
# Railway сам выставляет PORT; NODE_ENV=production уже в npm run start:server.

# Apollo Server (локально; на Railway используй PORT из панели)
SERVER_PORT=4000

# Браузер: публичный URL GraphQL (на проде — https://<railway-host>/graphql)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:4000/graphql"

# Vercel Server Components / route handlers → тот же URL, что и NEXT_PUBLIC_GRAPHQL_URL на проде
INTERNAL_GRAPHQL_URL="http://localhost:4000/graphql"

# Лендинг: ссылка «в приложение» (на проде — https://<ваш-web>.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:5000"
