# Database (Neon / локальный Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fullstack_db?schema=public"

# Neon: для `npm run db:push:schema` / миграций — строка «Direct» из консоли (хост без фрагмента -pooler).
# Рантайм (Next/Railway) может использовать pooled DATABASE_URL.
# DIRECT_URL="postgresql://user:pass@ep-xxx.c-2.region.aws.neon.tech/neondb?sslmode=require"

# Если P1001: уберите из URL параметр channel_binding=require (часто мешает node-pg).
# Опционально: DATABASE_SSL=true | false | не задавать (авто при sslmode=require и облачных хостах)
# DATABASE_SSL=

# --- Railway (только GraphQL API; Next — на Vercel) ---
# При импорте монорепы Railway может создать @repo/web, @repo/landing, @repo/server —
# лишние сервисы Next удалите; оставьте только API. DATABASE_URL — Neon pooled.
# Root Directory: пусто (корень репо) → читается корневой railway.json;
# или только server с Root Directory apps/server → apps/server/railway.json.
# Railway сам выставляет PORT; NODE_ENV=production уже в npm run start:server.

# Apollo Server (локально; на Railway используй PORT из панели)
SERVER_PORT=4000

# Браузер: публичный URL GraphQL (на проде — https://<railway-host>/graphql)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:4000/graphql"

# API routes (login/register): задайте на Vercel обязательно — тот же URL, что и публичный GraphQL:
INTERNAL_GRAPHQL_URL="http://localhost:4000/graphql"
# или GRAPHQL_URL (без префикса NEXT_PUBLIC_) — тоже для server runtime

# --- Локальный Next, но API на проде (Railway) ---
# В корневом .env (подхватывается apps/web через next.config loadEnvConfig):
# NEXT_PUBLIC_GRAPHQL_URL=https://<твой-сервис>.up.railway.app/graphql
# INTERNAL_GRAPHQL_URL=https://<тот-же>/graphql
# DATABASE_URL — тот же Neon, что и у прода (иначе локальные данные ≠ прод).
# Если в браузере блокирует CORS — в Apollo на Railway должны быть разрешены origin http://localhost:5000 (или твой порт).

# --- Vercel: сначала проект apps/web, потом apps/landing ---
# Web (production): DATABASE_URL, SESSION_SECRET,
# INTERNAL_GRAPHQL_URL = https://<railway>/graphql, NEXT_PUBLIC_GRAPHQL_URL — то же (для браузера)
# SESSION_SECRET="сгенерируй openssl rand -base64 32"

# Лендинг: куда вести кнопки «Войти / Поиск / …» (прод: https://realty-pro-web.vercel.app)
NEXT_PUBLIC_WEB_APP_URL="https://realty-pro-web.vercel.app"
# Устар.: раньше модалка редиректила на APP_URL/register; модалка отключена.
NEXT_PUBLIC_APP_URL="http://localhost:5000"
